# ─── Server ───────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── PostgreSQL (Structured Data) ─────────────────
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DATABASE=smartfarm_db
PG_USER=postgres
PG_PASSWORD=SmartFarmPG2026!

# ─── MongoDB (Unstructured Data) ──────────────────
MONGO_URI=mongodb://localhost:27017/smartfarm_nosql

# ─── JWT Auth ─────────────────────────────────────
JWT_SECRET=your_super_secret_key_change_this
JWT_EXPIRES_IN=7d

# ─── File Uploads ─────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5000
